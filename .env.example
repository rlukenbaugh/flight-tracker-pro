VITE_ENABLE_LIVE_FLIGHTS=false

# Optional: point the desktop build or an alternate frontend to a hosted backend.
# Leave blank on the main Vercel deployment so same-origin /api routes are used.
VITE_API_BASE_URL=

# Optional: label the frontend environment in the UI.
VITE_APP_ENVIRONMENT=

# Supabase client auth
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase service role for hosted API persistence and telemetry.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Stripe payment links for premium plans
VITE_STRIPE_PAYMENT_LINK_ELITE=
VITE_STRIPE_PAYMENT_LINK_CONCIERGE=

# Server-side live flight provider for Vercel or another backend runtime
DUFFEL_API_TOKEN=
DUFFEL_API_BASE_URL=

# GitHub Releases publishing for electron-updater / electron-builder
GH_TOKEN=

# Windows code signing for installer/executable
# Example: CSC_LINK=file:///C:/certs/flight-tracker-pro.pfx
CSC_LINK=
CSC_KEY_PASSWORD=

# Optional desktop release channel label: stable, preview, or beta
FLIGHT_TRACKER_RELEASE_CHANNEL=
